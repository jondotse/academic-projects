body {
  background-color: #fff;
  color: #333;
  margin: 0;
  font: 1.2em / 1.2 Arial, Helvetica, sans-serif;
}
header {
  background-color: black;
  padding: 25px;
  position: sticky;
  position: -webkit-sticky;
  top: 0;
  box-shadow: 0px 4px 10px black;
}

img {
    max-width: 100%;
    display: block;
}

.logo {
  text-align: center;
  padding: 0;
  margin: 0;
  list-style: none;
  position: sticky;
  position: -webkit-sticky;
  top: 0;
}

.flex {
  margin: 0 auto;
  padding: 0 20px;
 
  box-shadow: -5px 5px 905px gray;
  display: flex;
  flex-wrap: wrap;
}


nav {
  background-color: white; 
  overflow:auto; 
  position: sticky;
  top: 53px;
  box-shadow: 0px -2px 5px gold;

}

nav ul {
  list-style-type: none; 
  margin: 0;
  padding: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  

}

nav ul li {
  margin-right: 5px; 
}

nav ul li a {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 5px 5px;
  text-decoration-line: none; 
  color: black;
  transition: background-color 0.3s ease; 
  

}

nav ul li a:hover {
  background-color: beige; 
  color: black; 
  padding: 5px 5px 5px 5px;

}
nav ul li a.active {
  background-color: beige; 
  color: black; 
  padding: 5px 5px 5px 5px;

}



.feature {
   
    float: left;
    margin-right: 20px;
    margin-bottom: 10px;
    box-shadow: 0px 0px 5px gray
}
article{
  width: 100%;
  margin: 0 auto;
}

.img_ar{
  background-image: url("DSC_1904.JPG");
  background-size: 980px;
  background-position: top;
  background-repeat: no-repeat;
  margin: 0 auto;
}


   /* Footer css */

#footer-nav {
  background-color: black; 
  overflow: hidden; 

  bottom: 0;
  width: 100%;
  margin: 0 auto;
  display: flex;
  justify-content: center;
  max-width: 1120px;
  box-shadow: 0px -5px 5px gray, 1px 2px 5px gray, -1px 2px 5px gray;



}


#footer-nav ul {
  list-style-type: none; 
  margin: 0;
  padding: 0px;
  display: flex;
  justify-content: center;
  align-items: center;
 
 

}

#footer-nav ul li {
  margin-right: 15px; 
}

#footer-nav ul li a {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 5px 15px;
  text-decoration-line: none; 
  color: white; 
  transition: background-color 0.3s ease; 
 

}

#footer-nav ul li a:hover {
  background-color: beige; 
  color: black; 
  
}
#footer-nav ul li a.active {
  background-color: beige; 
  color: black; 

}
.pfooter {
  margin: 0 auto;
  padding: 0;
  box-shadow: 0px 0px 5px gray
}


.gridcontainer {
  display: grid;
  grid-gap:10px;
  grid-template-columns: 1fr 1fr;
  margin: 20px;
}

/*contact page */
form {
  size: 25px;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 25px;
    background-color: beige;
    color: black;
    border: 4px solid white;
    padding: 30px;
}

.contact{
    margin: 5px ;

}



/* Small devices (portrait tablets and large phones, 600px and up) */
@media only screen and (min-width: 600px) {
  .cportrait {width: 2500px;}
  
}

/* Medium devices (landscape tablets, 768px and up) */
@media only screen and (min-width: 768px) {
  .cportrait {width: 2500px;}
  .flex1 { size: 25px;}
} 

/* Large devices (laptops/desktops, 992px and up) */
@media only screen and (min-width: 992px) {
  .cportrait {width: 2500px;}
  .flex1 { size: 25px;}
} 

/* Extra large devices (large laptops and desktops, 1200px and up) */
@media only screen and (min-width: 1200px) {
  .cportrait {width: 500px;}
}


